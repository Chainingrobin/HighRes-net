{
  "paths": {
    "prefix": "data/",
    "checkpoint_dir": "models/weights",
    "tb_log_file_dir": "tb_logs/"
  },

  "network": {
    "encoder": {
      "in_channels": 2,
      "num_layers": 2,
      "kernel_size": 3,
      "channel_size": 64
    },
    "recursive": {
      "alpha_residual": true,
      "in_channels": 64,
      "num_layers": 2,
      "kernel_size": 3
    },
    "decoder": {
      "deconv": {
        "in_channels": 64,
        "kernel_size": 4,
        "stride": 2,
        "padding": 1,
        "out_channels": 64
      },
      "final": {
        "in_channels": 64,
        "kernel_size": 1,
        "out_channels": 1
      }
    }
  },

  "training": {
    "num_epochs": 30,
    "batch_size": 8,

    "min_L": 7,
    "n_views": 7,
    "n_workers": 4,
    "crop": 1,

    "lr": 0.0003,
    "lr_step": 3,
    "lr_decay": 0.95,

    "load_lr_maps": false,
    "beta": 0.0,

    "create_patches": false,
    "patch_size": 128,
    "val_proportion": 0.2,
    "lambda": 0.000001,
    "lambda_shift_reg": 0.000001,
    "lambda_range": 0.003,
    "lambda_tv": 0.00005,
    "lambda_edge_tv": 0.0002,
    "edge_aware_k": 10.0,
    "lambda_freq": 0.01,
    "freq_low_ratio": 0.12,
    "freq_high_ratio": 0.28,
    "freq_use_log_magnitude": true,
    "smoothness_mode": "freq_band"
  }
}
